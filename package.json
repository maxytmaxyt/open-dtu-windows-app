{
  "name": "windows-opendtu-dashboard",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "dev": "electron . --enable-logging"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "chart.js": "^4.4.0",
    "dotenv": "^16.3.0",
    "node-wifi": "^2.0.0",
    "auto-launch": "^5.0.5",
    "systeminformation": "^5.21.0",
    "electron-store": "^8.1.0",
    "node-notifier": "^10.0.1",
    "node-global-key-listener": "^0.1.1",
    "shelljs": "^0.8.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.solar.dashboard",
    "productName": "OpenDTU Pro Dashboard",
    "win": {
      "target": "portable",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "directories": {
      "output": "dist"
    }
  }
}
